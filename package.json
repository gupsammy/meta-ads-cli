{
  "name": "meta-ads",
  "version": "0.6.0",
  "description": "Command-line interface for the Meta (Facebook) Marketing API",
  "type": "module",
  "bin": {
    "meta-ads": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "postinstall": "node -e \"console.log('\\n  Run: meta-ads setup  to configure your account.\\n')\""
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cli",
    "marketing",
    "meta",
    "facebook",
    "ads",
    "meta-ads",
    "marketing-api"
  ],
  "author": "Samarth Gupta",
  "license": "MIT",
  "dependencies": {
    "cli-table3": "^0.6.4",
    "commander": "^12.1.0",
    "csv-stringify": "^6.5.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.5.0",
    "nock": "^14.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
